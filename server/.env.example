# AIRA Backend Configuration Example
# Copy this file to .env and update values as needed
# REQUIRED: GEMINI_API_KEY must be set or the server will not start

# Environment mode (development | production)
NODE_ENV=development

# Server Port (default: 3000)
PORT=3000

# CORS allowed origins (comma-separated URLs)
# Development: http://localhost:3000 or http://localhost:5173 (if using Vite)
# Production: https://yourdomain.com,https://www.yourdomain.com
# Note: Always include the exact origin (protocol + domain + port)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Database file path
# Can be absolute: /var/lib/aira/aira.db
# Or relative to server/: ./aira.db or ../data/aira.db
DATABASE_PATH=./aira.db

# AQICN data fetch interval in milliseconds (default: 300000 = 5 minutes)
# Formula: minutes * 60 * 1000
# Examples: 60000 (1 min), 300000 (5 mins), 600000 (10 mins)
FETCH_INTERVAL=300000

# Old data purge interval in milliseconds (default: 2592000000 = 30 days)
# Formula: days * 24 * 60 * 60 * 1000
# Examples: 86400000 (1 day), 604800000 (7 days), 2592000000 (30 days)
PURGE_INTERVAL=2592000000

# Enable automatic purge loop (default: false — disabled during development)
# Set to 'true' in production to auto-purge data older than 30 days
ENABLE_PURGE=false

# REQUIRED: Google Gemini API key for AI recommendations
# Get from: https://aistudio.google.com/app/apikey
# If missing, server will not start
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# Note: AQICN API token is hardcoded in server/fetcher.js (non-sensitive public data)
